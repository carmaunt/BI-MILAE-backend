generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VISUALIZADOR
}

enum Status {
  PENDENTE
  ATIVO
  INATIVO
}

enum Faccao {
  BDM
  CV
  PCC
  KLV
  NAO_VINCULADO
}

model Milae {
  id        Int      @id @default(autoincrement())
  data      DateTime
  hora      String
  local     String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentes     MilaeAgente[]
  resistentes Resistente[]

  @@map("milae")
}

model Agente {
  id        Int      @id @default(autoincrement())
  nome      String
  matricula String   @unique
  opm       String
  vtr       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  milaeLinks MilaeAgente[]

  @@map("agentes")
}

model MilaeAgente {
  milaeId  Int
  agenteId Int

  milae  Milae  @relation(fields: [milaeId], references: [id], onDelete: Cascade)
  agente Agente @relation(fields: [agenteId], references: [id], onDelete: Cascade)

  @@id([milaeId, agenteId])
  @@map("milae_agentes")
}

model Resistente {
  id        Int      @id @default(autoincrement())
  milaeId   Int
  nome      String?
  idade     Int?
  faccao    Faccao
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  milae Milae @relation(fields: [milaeId], references: [id], onDelete: Cascade)

  @@map("resistentes")
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(VISUALIZADOR)
  status    Status   @default(PENDENTE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
